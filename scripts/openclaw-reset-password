#!/usr/bin/env node
// openclaw-reset-password — Reset admin panel password from inside the container
// Usage: openclaw-reset-password
//   or:  docker exec -it openclaw-pro openclaw-reset-password

'use strict';

const crypto = require('crypto');
const fs = require('fs');
const path = require('path');
const readline = require('readline');

const CONFIG_PATH = '/root/.openclaw/docker-config.json';

function readConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8')); }
  catch { return {}; }
}

function writeConfig(cfg) {
  fs.mkdirSync(path.dirname(CONFIG_PATH), { recursive: true });
  fs.writeFileSync(CONFIG_PATH, JSON.stringify(cfg, null, 2), { mode: 0o600 });
}

function pbkdf2HashPassword(password) {
  const iter = 150000;
  const digest = 'sha256';
  const salt = crypto.randomBytes(16).toString('hex');
  const hash = crypto.pbkdf2Sync(password, Buffer.from(salt, 'hex'), iter, 32, digest).toString('hex');
  return { algo: 'pbkdf2', iter, digest, salt, hash };
}

function validatePassword(pw) {
  if (!pw || typeof pw !== 'string') return '密码不能为空';
  if (pw.length < 8) return '密码至少8位';
  if (!/[A-Z]/.test(pw)) return '密码需包含至少一个大写字母';
  if (!/[a-z]/.test(pw)) return '密码需包含至少一个小写字母';
  if (!/[0-9]/.test(pw)) return '密码需包含至少一个数字';
  if (!/[^A-Za-z0-9]/.test(pw)) return '密码需包含至少一个特殊字符';
  return null;
}

function ask(prompt) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout, terminal: false });
  process.stdout.write(prompt);
  // Suppress echo so password is hidden
  if (process.stdin.isTTY) process.stdin.setRawMode(true);
  return new Promise(resolve => {
    let buf = '';
    const onData = (ch) => {
      const c = ch.toString();
      if (c === '\n' || c === '\r') {
        process.stdin.removeListener('data', onData);
        if (process.stdin.isTTY) process.stdin.setRawMode(false);
        rl.close();
        process.stdout.write('\n');
        resolve(buf);
      } else if (c === '\u0003') {
        process.stdout.write('\n');
        process.exit(130);
      } else if (c === '\u007f' || c === '\b') {
        if (buf.length > 0) buf = buf.slice(0, -1);
      } else {
        buf += c;
      }
    };
    process.stdin.on('data', onData);
  });
}

async function main() {
  // Auto-escalate to root if config is unreadable
  if (process.getuid && process.getuid() !== 0) {
    try { fs.accessSync(CONFIG_PATH, fs.constants.R_OK); }
    catch {
      const { execFileSync } = require('child_process');
      try {
        execFileSync('sudo', [process.execPath, __filename], { stdio: 'inherit' });
        process.exit(0);
      } catch (e) {
        process.exit(e.status || 1);
      }
    }
  }

  console.log('');
  console.log('🐾 OpenClaw 管理面板 — 密码重置工具');
  console.log('====================================');
  console.log('');

  const cfg = readConfig();
  if (!cfg.webAuth?.users?.admin) {
    console.log('⚠️  当前未设置管理密码（首次使用请通过 Web 面板设置）');
    process.exit(1);
  }

  if (!process.stdin.isTTY) {
    console.error('❌ 需要交互式终端（TTY）。请通过 SSH 登录或使用 docker exec -it 运行此命令。');
    process.exit(1);
  }

  const pw1 = await ask('请输入新密码: ');
  const err = validatePassword(pw1);
  if (err) {
    console.error(`❌ ${err}`);
    process.exit(1);
  }

  const pw2 = await ask('请再次输入新密码: ');
  if (pw1 !== pw2) {
    console.error('❌ 两次输入的密码不一致');
    process.exit(1);
  }

  cfg.webAuth.users.admin.password = pbkdf2HashPassword(pw1);
  cfg.webAuth.users.admin.passwordChangedAt = new Date().toISOString();
  writeConfig(cfg);

  // Restart web panel to clear login lockout state
  try {
    const { execSync } = require('child_process');
    execSync('pkill -f "node server.js" 2>/dev/null || true', { stdio: 'ignore', timeout: 3000 });
  } catch {}

  console.log('');
  console.log('✅ 管理密码已重置成功！登录锁定已清除。');
  console.log('   请返回 Web 面板使用新密码登录。');
  console.log('');
  process.exit(0);
}

main().catch(e => {
  console.error('❌ 错误:', e.message);
  process.exit(1);
});
